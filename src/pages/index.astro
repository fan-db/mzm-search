---
import Base from '../layouts/Base.astro';
import videos from '../data/videos.json';

// カテゴリの一覧を重複なく取り出す（絞り込みのプルダウン用）
const categories = [...new Set(videos.map(v => v.category))].sort();
---
<Base title="MZM Fan Archive">
  <div class="controls">
    <input
      type="search"
      id="search-input"
      placeholder="キーワードで検索（タイトル・ゲスト・タグなど）"
      aria-label="動画を検索"
    />
    <div class="controls-row">
      <select id="category-select" aria-label="カテゴリで絞り込み">
        <option value="">すべてのカテゴリ</option>
        {categories.map(c => <option value={c}>{c}</option>)}
      </select>
      <select id="sort-select" aria-label="並び替え">
        <option value="asc">番号: 古い順</option>
        <option value="desc">番号: 新しい順</option>
      </select>
    </div>
  </div>

  <p id="result-count" class="result-count"></p>

  <ul id="video-list" class="video-list">
    {videos.map(v => (
      <li
        class="video-row"
        data-title={v.title}
        data-guest={v.guest}
        data-category={v.category}
        data-tags={v.tags}
        data-numbering={v.numbering}
      >
        <a href={`/videos/${v.videoId}/`} class="video-link">
          <div class="thumb-wrap">
            <img src={v.thumbnail} alt="" loading="lazy" />
            <span class="numbering-badge">#{v.numbering}</span>
          </div>
          <div class="video-info">
            <p class="video-title">{v.title}</p>
            {v.guest && <p class="video-guest">ゲスト: {v.guest}</p>}
            <p class="video-meta">
              <span class="category-pill">{v.category}</span>
              <span class="date">{new Date(v.publishedAt).toLocaleDateString('ja-JP')}</span>
            </p>
          </div>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .controls {
      position: sticky;
      top: 0;
      background: var(--bg);
      padding: 1rem 0;
      z-index: 10;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
    }

    #search-input {
      width: 100%;
      padding: 0.8rem 1rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 1rem;
      font-family: inherit;
    }

    .controls-row {
      display: flex;
      gap: 0.6rem;
      margin-top: 0.6rem;
    }

    .controls-row select {
      flex: 1;
      padding: 0.5rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
    }

    .result-count {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin: 0 0 1rem;
    }

    .video-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .video-row {
      border-bottom: 1px solid var(--border);
    }

    .video-link {
      display: flex;
      gap: 1rem;
      padding: 0.9rem 0.4rem;
      border-radius: 10px;
      transition: background 0.15s ease;
    }

    .video-link:hover, .video-link:focus-visible {
      background: var(--surface-hover);
    }

    .thumb-wrap {
      position: relative;
      flex-shrink: 0;
      width: 120px;
      height: 68px;
      border-radius: 8px;
      overflow: hidden;
      background: var(--surface);
    }

    .thumb-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* 三日月バッジ：サムネ左上に重ねる、このサイトのサイン要素 */
    .numbering-badge {
      position: absolute;
      top: -6px;
      left: -6px;
      background: var(--accent-moon);
      color: #12101c;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.03em;
      padding: 2px 8px 2px 10px;
      border-radius: 0 0 10px 0;
      box-shadow: 0 2px 8px rgba(255, 209, 102, 0.35);
    }

    .video-info {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0; /* 長いタイトルの折り返しのため */
    }

    .video-title {
      margin: 0 0 0.3rem;
      font-weight: 700;
      font-size: 0.98rem;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .video-guest {
      margin: 0 0 0.3rem;
      color: var(--text-muted);
      font-size: 0.85rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .video-meta {
      margin: 0;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.78rem;
    }

    .category-pill {
      background: rgba(139, 92, 246, 0.18);
      color: var(--accent-fang);
      padding: 2px 8px;
      border-radius: 999px;
    }

    .date {
      color: var(--text-muted);
    }
  </style>

  <script>
    // 検索・絞り込み・並び替えをブラウザ内だけで完結させる
    // (データ件数が少ないので、サーバーやライブラリを使わずシンプルに実現)
    const searchInput = document.getElementById('search-input');
    const categorySelect = document.getElementById('category-select');
    const sortSelect = document.getElementById('sort-select');
    const list = document.getElementById('video-list');
    const resultCount = document.getElementById('result-count');
    const rows = Array.from(document.querySelectorAll('.video-row'));

    function applyFilters() {
      const keyword = searchInput.value.trim().toLowerCase();
      const category = categorySelect.value;
      let visibleCount = 0;

      for (const row of rows) {
        const haystack = [
          row.dataset.title,
          row.dataset.guest,
          row.dataset.category,
          row.dataset.tags,
        ].join(' ').toLowerCase();

        const matchesKeyword = !keyword || haystack.includes(keyword);
        const matchesCategory = !category || row.dataset.category === category;
        const visible = matchesKeyword && matchesCategory;

        row.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      }

      resultCount.textContent = `${visibleCount} 件表示中（全 ${rows.length} 件）`;
    }

    function applySort() {
      const order = sortSelect.value; // "asc" or "desc"
      const sorted = [...rows].sort((a, b) => {
        const diff = Number(a.dataset.numbering) - Number(b.dataset.numbering);
        return order === 'asc' ? diff : -diff;
      });
      sorted.forEach(row => list.appendChild(row)); // 並び替えた順にDOMへ再配置
    }

    searchInput.addEventListener('input', applyFilters);
    categorySelect.addEventListener('change', applyFilters);
    sortSelect.addEventListener('change', applySort);

    applyFilters(); // 初期表示
  </script>
</Base>