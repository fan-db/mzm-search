---
import Base from '../layouts/Base.astro';
import videos from '../data/videos.json';

// 全動画のカテゴリ配列を1つに展開してから、重複なく取り出す
const categories = [...new Set(videos.flatMap(v => v.categories))].sort();
---
<Base title="MZM Fan Archive">
  <div class="controls">
    <input
      type="search"
      id="search-input"
      placeholder="検索…"
      aria-label="動画を検索"
    />
    <div class="controls-row">
      <div class="category-dropdown">
        <button type="button" id="category-toggle" class="category-toggle" aria-expanded="false">
          カテゴリで絞り込み <span id="category-count"></span>
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div id="category-panel" class="category-panel" hidden>
          {categories.map(c => (
            <label class="category-option">
              <input type="checkbox" class="category-checkbox" value={c} />
              {c}
            </label>
          ))}
        </div>
      </div>

      <select id="sort-select" aria-label="並び替え">
        <option value="asc">番号: 古い順</option>
        <option value="desc">番号: 新しい順</option>
      </select>
    </div>
  </div>

  <p id="result-count" class="result-count"></p>

  <ul id="video-list" class="video-list">
    {videos.map(v => (
      <li
        class="video-row"
        data-title={v.title}
        data-guest={v.guest}
        data-categories={v.categories.join(',')}
        data-tags={v.tags}
        data-numbering={v.numbering}
      >
        <div class="thumb-wrap">
          <img src={v.thumbnail} alt="" loading="lazy" />
        </div>
        <div class="video-info">
          <p class="video-title">{v.title}</p>
          {v.guest && <p class="video-guest">ゲスト: {v.guest}</p>}
          <p class="video-meta">
            <span class="numbering-badge">#{v.numbering}</span>
            <span class="category-pill">{v.categories.join(', ')}</span>
            <span class="date">{new Date(v.publishedAt).toLocaleDateString('ja-JP')}</span>
          </p>
        </div>
        <a href={v.url} target="_blank" rel="noopener noreferrer" class="youtube-button">
          YouTubeで見る
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .controls {
      position: sticky;
      top: 0;
      background: var(--bg);
      padding: 1rem 0;
      z-index: 10;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
    }

    #search-input {
      width: 100%;
      padding: 0.8rem 1rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s ease;
    }

    #search-input::placeholder {
      color: var(--text-muted);
    }

    #search-input:focus {
      outline: none;
      border-image: linear-gradient(90deg, var(--accent-cyan), var(--accent-magenta)) 1;
    }

    .controls-row {
      display: flex;
      gap: 0.6rem;
      margin-top: 0.6rem;
      position: relative;
    }

    .controls-row select {
      flex: 1;
      padding: 0.5rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
    }

    .category-dropdown {
      position: relative;
      flex: 1;
    }

    .category-toggle {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.4rem;
      padding: 0.5rem 0.7rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
      font-size: 0.9rem;
      cursor: pointer;
    }

    #category-count {
      color: var(--accent-cyan);
      font-weight: 700;
    }

    .chevron {
      flex-shrink: 0;
      transition: transform 0.15s ease;
    }

    .category-toggle[aria-expanded="true"] .chevron {
      transform: rotate(180deg);
    }

    .category-panel {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.5rem;
      max-height: 240px;
      overflow-y: auto;
      z-index: 20;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .category-option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.3rem;
      font-size: 0.88rem;
      cursor: pointer;
      border-radius: 6px;
    }

    .category-option:hover {
      background: var(--surface-hover);
    }

    .category-checkbox {
      accent-color: var(--accent-violet);
      width: 16px;
      height: 16px;
    }

    .result-count {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin: 0 0 1rem;
    }

    .video-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .video-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.9rem 0.4rem;
      border-bottom: 1px solid var(--border);
    }

    .thumb-wrap {
      position: relative;
      flex-shrink: 0;
      width: 120px;
      height: 68px;
      border-radius: 8px;
      overflow: hidden;
      background: var(--surface);
      border: 1px solid transparent;
      transition: border-image 0.2s ease;
    }

    .video-row:hover .thumb-wrap {
      border-image: linear-gradient(135deg, var(--accent-cyan), var(--accent-magenta)) 1;
    }

    .thumb-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .video-info {
      flex: 1;
      min-width: 0;
    }

    .video-title {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      margin: 0 0 0.3rem;
      font-weight: 700;
      font-size: 0.98rem;
      color: var(--text);
    }

    .video-guest {
      margin: 0 0 0.3rem;
      color: var(--text-muted);
      font-size: 0.85rem;
      white-space: normal;
      overflow-wrap: break-word;
    }

    .video-meta {
      margin: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      flex-wrap: wrap;
    }

    .numbering-badge {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.03em;
      background: linear-gradient(90deg, var(--accent-cyan), var(--accent-magenta));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .category-pill {
      background: var(--surface-hover);
      color: var(--text-muted);
      padding: 2px 10px;
      border-radius: 999px;
    }

    .date { color: var(--text-muted); }

    .youtube-button {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.6rem 1.1rem;
      background: var(--accent-violet);
      color: #ffffff;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.82rem;
      text-decoration: none;
      white-space: nowrap;
    }

    .youtube-button:hover { filter: brightness(1.15); }

    @media (max-width: 520px) {
      .video-row { flex-wrap: wrap; }
      .youtube-button { margin-left: calc(120px + 1rem); }
    }
  </style>

  <script>
    const searchInput = document.getElementById('search-input');
    const sortSelect = document.getElementById('sort-select');
    const list = document.getElementById('video-list');
    const resultCount = document.getElementById('result-count');
    const rows = Array.from(document.querySelectorAll('.video-row'));

    const categoryToggle = document.getElementById('category-toggle');
    const categoryPanel = document.getElementById('category-panel');
    const categoryCount = document.getElementById('category-count');
    const categoryCheckboxes = Array.from(document.querySelectorAll('.category-checkbox'));

    categoryToggle.addEventListener('click', () => {
      const isOpen = categoryPanel.hidden === false;
      categoryPanel.hidden = isOpen;
      categoryToggle.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('click', (e) => {
      if (!categoryToggle.contains(e.target) && !categoryPanel.contains(e.target)) {
        categoryPanel.hidden = true;
        categoryToggle.setAttribute('aria-expanded', 'false');
      }
    });

    function getSelectedCategories() {
      return categoryCheckboxes.filter(cb => cb.checked).map(cb => cb.value);
    }

    function updateCategoryCountLabel() {
      const n = getSelectedCategories().length;
      categoryCount.textContent = n > 0 ? `(${n})` : '';
    }

    function applyFilters() {
      const keyword = searchInput.value.trim().toLowerCase();
      const selectedCategories = getSelectedCategories();
      let visibleCount = 0;

      for (const row of rows) {
        const haystack = [
          row.dataset.title,
          row.dataset.guest,
          row.dataset.categories,
          row.dataset.tags,
        ].join(' ').toLowerCase();

        const matchesKeyword = !keyword || haystack.includes(keyword);

        // その動画が持つカテゴリ一覧(配列)を取り出す
        const videoCategories = row.dataset.categories.split(',');
        // 選択中のカテゴリのうち、1つでもこの動画が持っていればOK
        const matchesCategory =
          selectedCategories.length === 0 ||
          selectedCategories.some(sc => videoCategories.includes(sc));

        const visible = matchesKeyword && matchesCategory;

        row.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      }

      resultCount.textContent = `${visibleCount} 件表示中（全 ${rows.length} 件）`;
    }

    function applySort() {
      const order = sortSelect.value;
      const sorted = [...rows].sort((a, b) => {
        const diff = Number(a.dataset.numbering) - Number(b.dataset.numbering);
        return order === 'asc' ? diff : -diff;
      });
      sorted.forEach(row => list.appendChild(row));
    }

    searchInput.addEventListener('input', applyFilters);
    sortSelect.addEventListener('change', applySort);
    categoryCheckboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        updateCategoryCountLabel();
        applyFilters();
      });
    });

    applyFilters();
  </script>
</Base>