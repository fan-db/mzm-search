---
import Base from '../../layouts/Base.astro';
import videos from '../../data/videos.json';

// Astroに「videos.jsonの件数分、静的なページを生成して」と伝える設定
export function getStaticPaths() {
  return videos.map(v => ({
    params: { videoId: v.videoId },
    props: { video: v },
  }));
}

const { video } = Astro.props;
const publishedDate = new Date(video.publishedAt).toLocaleDateString('ja-JP');
---
<Base title={`${video.title} | MZM Fan Archive`}>
  <a href="/" class="back-link">← 一覧に戻る</a>

  <article class="detail">
    <div class="thumb-large">
      <img src={video.thumbnail} alt="" />
      <span class="numbering-badge">#{video.numbering}</span>
    </div>

    <h2>{video.title}</h2>

    <div class="meta-row">
      <span class="category-pill">{video.category}</span>
      <span class="date">{publishedDate}</span>
    </div>

    {video.guest && (
      <p class="detail-field">
        <span class="field-label">ゲスト</span>
        {video.guest}
      </p>
    )}

    {video.tags && (
      <p class="detail-field tags">
        <span class="field-label">メモ</span>
        {video.tags}
      </p>
    )}

    <a href={video.url} target="_blank" rel="noopener noreferrer" class="youtube-button">
      YouTubeで見る ↗
    </a>
  </article>

  <style>
    .back-link {
      display: inline-block;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
      font-size: 0.9rem;
    }
    .back-link:hover { color: var(--accent-moon); }

    .detail {
      max-width: 640px;
      margin: 0 auto;
    }

    .thumb-large {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 1.2rem;
    }

    .thumb-large img {
      width: 100%;
      display: block;
    }

    .thumb-large .numbering-badge {
      position: absolute;
      top: 0;
      left: 0;
      background: var(--accent-moon);
      color: #12101c;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      padding: 4px 14px 4px 12px;
      border-radius: 0 0 12px 0;
      box-shadow: 0 2px 10px rgba(255, 209, 102, 0.35);
    }

    .detail h2 {
      font-size: 1.3rem;
      margin: 0 0 0.6rem;
    }

    .meta-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.2rem;
      font-size: 0.85rem;
    }

    .category-pill {
      background: rgba(139, 92, 246, 0.18);
      color: var(--accent-fang);
      padding: 2px 10px;
      border-radius: 999px;
    }

    .date { color: var(--text-muted); }

    .detail-field {
      margin: 0 0 1rem;
      line-height: 1.7;
    }

    .field-label {
      display: block;
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.2rem;
    }

    .tags {
      white-space: pre-wrap; /* 改行を含む文章もそのまま表示 */
    }

    .youtube-button {
      display: inline-block;
      margin-top: 0.8rem;
      padding: 0.7rem 1.4rem;
      background: var(--accent-fang);
      color: #fff;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .youtube-button:hover {
      filter: brightness(1.1);
    }
  </style>
</Base>